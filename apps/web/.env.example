# Leave empty to call same-origin /api (Next.js proxies to Nest).
# Recommended so the HttpOnly refreshToken cookie is shared with middleware.
NEXT_PUBLIC_API_URL=
# Target for the Next.js rewrite proxy (server-side only).
API_PROXY_TARGET=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: Stripe publishable key for checkout UI mode note
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
