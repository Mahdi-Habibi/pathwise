# Leave empty to call same-origin /api (Next.js proxies to Nest in local/Docker).
# For GitHub Pages + a hosted API, set to your Nest origin (no trailing slash), e.g.:
# NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_URL=
# Target for the Next.js rewrite proxy (server-side only; ignored for GITHUB_PAGES builds).
API_PROXY_TARGET=http://localhost:3001
# Local: http://localhost:3000
# GitHub Pages: https://mahdi-habibi.github.io/pathwise
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Static in-browser demo (no Nest). Leave unset/false for local `pnpm dev`.
# GitHub Pages workflow sets this to true when NEXT_PUBLIC_API_URL is empty.
# NEXT_PUBLIC_DEMO_MODE=true
# Optional: Stripe publishable key for checkout UI mode note
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
