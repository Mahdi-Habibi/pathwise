# Copy to .env.docker and adjust secrets for production.
# Used by: docker compose --profile full up

# PostgreSQL (docker network hostname)
POSTGRES_USER=pathwise
POSTGRES_PASSWORD=pathwise
POSTGRES_DB=pathwise
DATABASE_URL=postgresql://pathwise:pathwise@postgres:5432/pathwise?schema=public

# API
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
NODE_ENV=production
SEED_DATABASE=true
DB_HOST=postgres
DB_PORT=5432
DB_USER=pathwise

# Auth — CHANGE IN PRODUCTION (min 32 chars)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-use-a-different-long-string
JWT_REFRESH_EXPIRES_IN=7d

# Frontend: leave NEXT_PUBLIC_API_URL empty so the browser uses same-origin /api,
# proxied by Next to the API container.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_PROXY_TARGET=http://api:3001

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email / SMTP (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Pathwise <noreply@pathwise.dev>
