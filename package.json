{
  "name": "pathwise",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "description": "Pathwise — Adaptive Learning Platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mahdi-Habibi/pathwise.git"
  },
  "homepage": "https://github.com/Mahdi-Habibi/pathwise#readme",
  "bugs": {
    "url": "https://github.com/Mahdi-Habibi/pathwise/issues"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm --filter @pathwise/web dev\" \"pnpm --filter @pathwise/api dev\"",
    "build": "pnpm --filter @pathwise/shared build && pnpm --filter @pathwise/api build && pnpm --filter @pathwise/web build",
    "start": "concurrently -n web,api -c blue,green \"pnpm --filter @pathwise/web start\" \"pnpm --filter @pathwise/api start:prod\"",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @pathwise/web test:e2e",
    "db:generate": "pnpm --filter @pathwise/api prisma:generate",
    "db:migrate": "pnpm --filter @pathwise/api prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @pathwise/api prisma:migrate:deploy",
    "db:seed": "pnpm --filter @pathwise/api prisma:seed",
    "docker:db": "docker compose up -d postgres",
    "docker:db:down": "docker compose down",
    "docker:db:reset": "docker compose down -v && docker compose up -d postgres",
    "docker:build": "docker compose --profile full build",
    "docker:up": "docker compose --profile full up -d",
    "docker:down": "docker compose --profile full down",
    "docker:logs": "docker compose --profile full logs -f",
    "docker:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-docker-prereqs.ps1",
    "docker:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/docker-reset.ps1",
    "portable:zip": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-portable.ps1",
    "portable:zip:staged": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-portable-zip.ps1",
    "docker:setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env.docker')){fs.copyFileSync('.env.docker.example','.env.docker'); console.log('Created .env.docker');} else {console.log('.env.docker already exists');}\"",
    "docker:ghcr:up": "docker compose -f docker-compose.ghcr.yml --env-file .env.docker up -d",
    "docker:ghcr:down": "docker compose -f docker-compose.ghcr.yml --env-file .env.docker down",
    "docker:ghcr:pull": "docker compose -f docker-compose.ghcr.yml --env-file .env.docker pull",
    "postinstall": "pnpm db:generate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.31.0"
  }
}
