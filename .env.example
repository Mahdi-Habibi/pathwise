# Frontend (apps/web) — leave NEXT_PUBLIC_API_URL empty to use same-origin /api proxy
NEXT_PUBLIC_API_URL=
API_PROXY_TARGET=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (apps/api)
# Local dev (Postgres via Docker): host is localhost
DATABASE_URL=postgresql://pathwise:pathwise@localhost:5432/pathwise?schema=public
# Full Docker stack (api container): host is postgres — see .env.docker.example
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
NODE_ENV=development

# Auth — CHANGE IN PRODUCTION (min 32 chars)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-use-a-different-long-string
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (optional — dev mode auto-completes without Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email / SMTP (optional — logs to console + EmailLog in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Pathwise <noreply@pathwise.dev>
